# Configuração do Banco de Dados Neon.tech
# Copie este arquivo para .env e preencha com suas credenciais

# Para usar Neon.tech (PostgreSQL online)
USE_NEON=true
NEON_DATABASE_URL=postgresql://seu_usuario:sua_senha@ep-nome-do-endpoint.us-east-1.aws.neon.tech/seu_banco?sslmode=require

# Para usar SQLite local (padrão)
# USE_NEON=false
# NEON_DATABASE_URL=

# Chave secreta para sessões
SECRET_KEY=sua_chave_secreta_aqui

# Exemplo de URL do Neon.tech:
# postgresql://user123:password456@ep-calm-dust-123456.us-east-1.aws.neon.tech/agenda_db?sslmode=require